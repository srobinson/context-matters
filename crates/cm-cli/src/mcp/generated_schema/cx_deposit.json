{
  "description": "Batch-store conversation exchanges for future context. Each exchange (user/assistant pair) becomes an observation entry. Optional summary creates a linked observation with 'elaborates' relations to each exchange. All entries created in a single transaction. Maximum 50 exchanges per deposit.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "created_by": {
        "description": "Attribution string. Default: 'agent:claude-code'.",
        "type": "string"
      },
      "exchanges": {
        "description": "Conversation exchanges to store. Each exchange has 'user' (user message), 'assistant' (assistant response), and optional 'title' (explicit title, max 80 bytes; auto-generated from user message snippet if omitted). Maximum 50 exchanges per deposit.",
        "items": {
          "properties": {
            "assistant": {
              "type": "string"
            },
            "user": {
              "type": "string"
            }
          },
          "required": [
            "user",
            "assistant"
          ],
          "type": "object"
        },
        "type": "array"
      },
      "scope": {
        "description": "Singular write scope. Pass a canonical scope path string returned by read tools, or a structured singular selector: path, cwd_inferred, project, repo, or session. Exact scope chains are created if missing. Default: global.",
        "oneOf": [
          {
            "description": "Exact scope path string such as global/project:helioy/repo:context-matters, or cwd_inferred.",
            "type": "string"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "path"
                ],
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "path"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "cwd": {
                "type": "string"
              },
              "kind": {
                "enum": [
                  "cwd_inferred"
                ],
                "type": "string"
              }
            },
            "required": [
              "kind"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "project"
                ],
                "type": "string"
              },
              "project": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "project"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "repo"
                ],
                "type": "string"
              },
              "project": {
                "type": "string"
              },
              "repo": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "project",
              "repo"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "session"
                ],
                "type": "string"
              },
              "project": {
                "type": "string"
              },
              "repo": {
                "type": "string"
              },
              "session": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "project",
              "session"
            ],
            "type": "object"
          }
        ]
      },
      "summary": {
        "description": "Optional summary of the conversation. Stored as a separate observation entry linked to each exchange via 'elaborates' relations.",
        "type": "string"
      }
    },
    "required": [
      "exchanges"
    ],
    "type": "object"
  },
  "name": "cx_deposit",
  "outputSchema": {
    "description": "Deposit receipt: count, created exchange ids, optional summary id, and resolved scope path.",
    "properties": {
      "deposited": {
        "description": "Number of exchange entries created.",
        "minimum": 0,
        "type": "integer"
      },
      "entry_ids": {
        "description": "Created exchange entry ids.",
        "items": {
          "format": "uuid",
          "type": "string"
        },
        "type": "array"
      },
      "scope_path": {
        "description": "Resolved canonical scope path.",
        "type": "string"
      },
      "summary_id": {
        "description": "Created summary entry id, or null when no summary was provided."
      }
    },
    "required": [
      "deposited",
      "entry_ids",
      "scope_path"
    ],
    "type": "object"
  }
}
