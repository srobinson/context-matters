{
  "description": "Search cm entries by content across scopes. Returns FTS5 BM25-ranked hits. Use cx_search when you have a query and want results from multiple scopes, an unknown scope, or all scopes. Use cx_recall when you want priority-ordered context for a single known scope, walking ancestors. Recall is sharper but narrower.",
  "inputSchema": {
    "additionalProperties": false,
    "properties": {
      "cursor": {
        "description": "Opaque pagination cursor from a previous cx_search response. Pass next_cursor to fetch the next page.",
        "type": "string"
      },
      "kinds": {
        "description": "Filter to specific entry kinds (OR logic). Valid values: fact, decision, preference, lesson, reference, feedback, pattern, observation.",
        "items": {
          "type": "string"
        },
        "type": "array"
      },
      "limit": {
        "description": "Maximum number of entries to return. Default: 20, max: 200.",
        "type": "integer"
      },
      "query": {
        "description": "Required FTS5 search query. Use 1-3 keywords. Supports prefix queries (rust*), phrase queries (\"scope path\"), and boolean operators (AND, OR, NOT).",
        "type": "string"
      },
      "scope": {
        "description": "Scope input for content search. Pass a canonical scope path string, a singular selector such as cwd_inferred, project, repo, or session, or a broad selector: descendants, subtree, set, or all. descendants and subtree match the exact scope plus child scopes.",
        "oneOf": [
          {
            "description": "Exact scope path string such as global/project:helioy/repo:context-matters, or cwd_inferred.",
            "type": "string"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "path"
                ],
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "path"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "cwd": {
                "type": "string"
              },
              "kind": {
                "enum": [
                  "cwd_inferred"
                ],
                "type": "string"
              }
            },
            "required": [
              "kind"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "project"
                ],
                "type": "string"
              },
              "project": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "project"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "repo"
                ],
                "type": "string"
              },
              "project": {
                "type": "string"
              },
              "repo": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "project",
              "repo"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "session"
                ],
                "type": "string"
              },
              "project": {
                "type": "string"
              },
              "repo": {
                "type": "string"
              },
              "session": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "project",
              "session"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "descendants",
                  "subtree"
                ],
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "path"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "set"
                ],
                "type": "string"
              },
              "paths": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            },
            "required": [
              "kind",
              "paths"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": [
                  "all"
                ],
                "type": "string"
              }
            },
            "required": [
              "kind"
            ],
            "type": "object"
          }
        ]
      },
      "tags": {
        "description": "Filter to entries with any of these tags (OR logic). Pass a JSON array: [\"tag1\", \"tag2\"].",
        "items": {
          "type": "string"
        },
        "type": "array"
      }
    },
    "required": [
      "query",
      "scope"
    ],
    "type": "object"
  },
  "name": "cx_search",
  "outputSchema": {
    "description": "Search response: content-ranked rows and cursor pagination metadata.",
    "properties": {
      "entries": {
        "description": "FTS5-ranked search rows. Order is significant.",
        "items": {
          "properties": {
            "age": {
              "description": "Relative age string.",
              "type": "string"
            },
            "id": {
              "description": "Full UUID v7.",
              "format": "uuid",
              "type": "string"
            },
            "kind": {
              "enum": [
                "fact",
                "decision",
                "preference",
                "lesson",
                "reference",
                "feedback",
                "pattern",
                "observation"
              ],
              "type": "string"
            },
            "scope": {
              "type": "string"
            },
            "score": {
              "description": "Normalised relevance score in [0, 1].",
              "type": "number"
            },
            "snippet": {
              "description": "Smart snippet of the entry body, with matched query terms bracketed.",
              "type": "string"
            },
            "tags": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "title": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "score",
            "title",
            "snippet",
            "age",
            "scope",
            "kind",
            "tags"
          ],
          "type": "object"
        },
        "type": "array"
      },
      "header": {
        "description": "Search query envelope.",
        "properties": {
          "kinds_histogram": {
            "additionalProperties": {
              "minimum": 0,
              "type": "integer"
            },
            "description": "Per-kind counts for this page.",
            "type": "object"
          },
          "next_cursor": {
            "description": "Opaque cursor for the next page. Omitted when there are no more rows.",
            "type": "string"
          },
          "query": {
            "description": "FTS5 query supplied by the caller.",
            "type": "string"
          },
          "returned": {
            "description": "Number of rows in this page.",
            "minimum": 0,
            "type": "integer"
          },
          "scope_hits": {
            "additionalProperties": {
              "minimum": 0,
              "type": "integer"
            },
            "description": "Per-scope hit counts for this page.",
            "type": "object"
          },
          "tags_histogram": {
            "additionalProperties": {
              "minimum": 0,
              "type": "integer"
            },
            "description": "Per-tag counts for this page.",
            "type": "object"
          },
          "tokens": {
            "description": "Estimated token total of the full bodies in this page.",
            "minimum": 0,
            "type": "integer"
          }
        },
        "required": [
          "query",
          "returned",
          "scope_hits",
          "kinds_histogram",
          "tags_histogram",
          "tokens"
        ],
        "type": "object"
      }
    },
    "required": [
      "header",
      "entries"
    ],
    "type": "object"
  }
}
